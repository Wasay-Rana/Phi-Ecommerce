# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real keys.

# EmailJS (https://www.emailjs.com) — used to send order notification emails on checkout
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# WhatsApp business number for the floating chat button, with country code and no plus/leading zero (e.g. 923001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=923032823122
